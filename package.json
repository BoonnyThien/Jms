{
  "name": "coordinate-auto-clicker",
  "version": "1.0.0",
  "description": "Coordinate Auto-Clicker - Tự động click theo tọa độ",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder --win",
    "vite:dev": "vite --port 5173",
    "electron:dev": "electron ."
  },
  "dependencies": {
    "koffi": "^2.16.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vue-tsc": "^3.2.9",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.autoclicker.app",
    "productName": "Coordinate Auto-Clicker",
    "directories": {
      "output": "out"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
